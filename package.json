{
  "name": "founcode",
  "version": "1.2.0",
  "description": "Windows-first desktop orchestrator for AI coding agents (Blueprint -> Plan -> Execute -> Verify)",
  "main": "out/main/index.js",
  "author": "21Kent",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "biome format --write src",
    "icon": "node scripts/gen-icon.mjs",
    "dist": "node scripts/gen-icon.mjs && electron-vite build && electron-builder --win",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xyflow/react": "^12.11.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9",
    "zustand": "^5.0.14"
  }
}
